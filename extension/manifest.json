{
  "manifest_version": 3,
  "name": "Study With Me",
  "version": "1.0",
  "description": "Stay focused with a timer, goals, and ambient sounds.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "webNavigation",
    "identity"
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/widget.js"],
      "css": ["content/widget.css"]
    },
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["content/sync_bridge.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
